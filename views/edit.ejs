<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student | SMS Pro</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            padding: 40px;
            max-width: 500px;
            width: 100%;
        }

        .form-label {
            font-weight: 600;
            color: #555;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .input-group-text {
            background-color: #f8f9fa;
            border-right: none;
            color: #ffc107; /* Warning yellow for Edit theme */
        }

        .form-control {
            border-left: none;
            padding: 12px;
            border-radius: 0 8px 8px 0;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #ced4da;
        }

        .btn-update {
            background: linear-gradient(to right, #f6d365 0%, #fda085 100%);
            border: none;
            color: #fff;
            padding: 12px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(253, 160, 133, 0.4);
            color: #fff;
        }

        .header-icon {
            font-size: 3rem;
            color: #ffc107;
            margin-bottom: 20px;
        }
        
        .alert-info-custom {
            background: rgba(255, 193, 7, 0.1);
            border: 1px solid rgba(255, 193, 7, 0.2);
            color: #856404;
            font-size: 0.85rem;
            border-radius: 10px;
        }
    </style>
</head>
<body>

<div class="glass-card">
    <div class="text-center">
        <i class="fas fa-user-edit header-icon"></i>
        <h2 class="fw-bold">Edit Information</h2>
        <p class="text-muted mb-4">Modifying record for <strong><%= student.full_name %></strong></p>
    </div>

    <div class="alert alert-info-custom mb-4 text-center">
        <i class="fas fa-info-circle me-2"></i> Ensure all details are accurate before saving.
    </div>

    <form action="/update/<%= student.id %>" method="POST" id="editForm">
        <div class="mb-3">
            <label class="form-label">Student ID Number</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                <input type="text" name="student_id" value="<%= student.student_id %>" class="form-control" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
                <input type="text" name="full_name" value="<%= student.full_name %>" class="form-control" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Course / Program</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-book"></i></span>
                <input type="text" name="course" value="<%= student.course %>" class="form-control" required>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Year Level</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-layer-group"></i></span>
                    <input type="text" name="year_level" value="<%= student.year_level %>" class="form-control" required>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input type="email" name="email_address" value="<%= student.email_address %>" class="form-control" required>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-update">
                <i class="fas fa-sync-alt me-2"></i>Update Record
            </button>
            <a href="/" class="btn btn-light text-muted">
                <i class="fas fa-arrow-left me-2"></i>Cancel & Go Back
            </a>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Confirmation on update
    document.getElementById('editForm').addEventListener('submit', function(e) {
        Swal.fire({
            title: 'Updating Record...',
            text: 'Synchronizing changes with Aiven Database',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading()
            }
        });
    });
</script>

</body>
</html>
