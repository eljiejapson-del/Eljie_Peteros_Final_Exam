<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Management System | Pro Dashboard</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.07);
            --glass-border: rgba(255, 255, 255, 0.15);
            --accent-color: #00f2fe;
            --secondary-color: #4facfe;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: radial-gradient(circle at top right, #1e1e2f, #121212);
            color: #ffffff;
            min-height: 100vh;
            padding: 50px 0;
            overflow-x: hidden;
        }

        /* Animated Background Blobs */
        .blob {
            position: fixed;
            width: 500px;
            height: 500px;
            background: linear-gradient(135deg, var(--accent-color), var(--secondary-color));
            filter: blur(100px);
            border-radius: 50%;
            z-index: -1;
            opacity: 0.15;
            animation: move 20s infinite alternate;
        }

        @keyframes move {
            from { transform: translate(-10%, -10%); }
            to { transform: translate(20%, 20%); }
        }

        .main-card {
            background: var(--glass-bg);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid var(--glass-border);
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
        }

        .header-section {
            border-bottom: 1px solid var(--glass-border);
            margin-bottom: 30px;
            padding-bottom: 20px;
        }

        .table {
            color: #e0e0e0 !important;
            border-color: var(--glass-border);
        }

        .table thead th {
            background: rgba(255, 255, 255, 0.05) !important;
            color: var(--accent-color) !important;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            border: none;
            padding: 15px;
        }

        .table tbody tr {
            transition: all 0.3s ease;
            border-bottom: 1px solid var(--glass-border);
        }

        .table tbody tr:hover {
            background: rgba(255, 255, 255, 0.03) !important;
            transform: scale(1.005);
        }

        .btn-register {
            background: linear-gradient(45deg, #00f2fe, #4facfe);
            border: none;
            color: #000;
            font-weight: 700;
            border-radius: 12px;
            padding: 12px 25px;
            transition: all 0.3s;
        }

        .btn-register:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 242, 254, 0.4);
            color: #000;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            transition: all 0.3s;
            margin: 0 3px;
        }

        .badge-level {
            background: rgba(0, 242, 254, 0.1);
            color: var(--accent-color);
            border: 1px solid var(--accent-color);
            padding: 6px 15px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Customizing Search Bar and Pagination */
        .dataTables_filter input {
            background: var(--glass-bg) !important;
            border: 1px solid var(--glass-border) !important;
            color: white !important;
            border-radius: 10px;
            padding: 8px 15px;
        }

        .page-link {
            background: transparent !important;
            border: 1px solid var(--glass-border) !important;
            color: white !important;
        }

        .active > .page-link {
            background: var(--accent-color) !important;
            color: black !important;
            border: none !important;
        }
    </style>
</head>
<body>

<div class="blob"></div>

<div class="container animate__animated animate__fadeInUp">
    <div class="main-card">
        <div class="header-section d-flex justify-content-between align-items-center">
            <div>
                <h1 class="fw-bold mb-1"><i class="fas fa-database text-info me-3"></i>SMS <span class="text-info">PRO</span></h1>
                <p class="text-muted mb-0">Cloud-Based Student Management Terminal</p>
            </div>
            <a href="/add" class="btn btn-register animate__animated animate__pulse animate__infinite">
                <i class="fas fa-plus-circle me-2"></i>ADD NEW RECORD
            </a>
        </div>

        <div class="table-responsive mt-4">
            <table id="studentTable" class="table align-middle">
                <thead>
                    <tr>
                        <th><i class="fas fa-fingerprint me-2"></i>ID Number</th>
                        <th><i class="fas fa-user me-2"></i>Full Name</th>
                        <th><i class="fas fa-graduation-cap me-2"></i>Course</th>
                        <th><i class="fas fa-layer-group me-2"></i>Year</th>
                        <th><i class="fas fa-envelope me-2"></i>Email</th>
                        <th class="text-center">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    <% students.forEach(student => { %>
                        <tr>
                            <td class="text-info fw-bold"><%= student.student_id %></td>
                            <td class="fw-semibold"><%= student.full_name %></td>
                            <td><%= student.course %></td>
                            <td><span class="badge-level"><%= student.year_level %></span></td>
                            <td class="text-muted"><%= student.email_address %></td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center">
                                    <a href="/edit/<%= student.id %>" class="action-btn btn btn-outline-warning" title="Modify Record">
                                        <i class="fas fa-pen-to-square"></i>
                                    </a>
                                    <button onclick="confirmDelete('<%= student.id %>')" class="action-btn btn btn-outline-danger" title="Purge Record">
                                        <i class="fas fa-trash-can"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function() {
        $('#studentTable').DataTable({
            "pageLength": 5,
            "responsive": true,
            "language": {
                "search": "",
                "searchPlaceholder": "Search Terminal..."
            }
        });
    });

    function confirmDelete(id) {
        Swal.fire({
            title: 'Confirm Deletion',
            text: "This action will permanently remove this record from Aiven Cloud.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#00f2fe',
            cancelButtonColor: '#f8312f',
            confirmButtonText: 'Yes, Purge it!',
            background: '#1e1e2f',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/delete/' + id;
            }
        })
    }
</script>

</body>
</html>
